      <visual name="v"><geometry><box><size>0.7 0.7 1.8</size></box></geometry>
        <material><ambient>0.9 0.9 0.9 1</ambient><diffuse>0.9 0.9 0.9 1</diffuse></material>
      </visual>
    </link>
    <pose>9.65 5.65 0.9 0 0 0</pose>
  </model>

  <!-- CHAMBRE 1 (sud-ouest) -->
  <model name="bed_1">
    <static>true</static>
    <link name="link">
      <collision name="c"><geometry><box><size>2 1.6 0.5</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>2 1.6 0.5</size></box></geometry>
        <material><ambient>0.85 0.3 0.3 1</ambient><diffuse>0.85 0.3 0.3 1</diffuse></material>
      </visual>
    </link>
    <pose>-7.5 -4.5 0.25 0 0 0</pose>
  </model>

  <model name="wardrobe_1">
    <static>true</static>
    <link name="link">
      <collision name="c"><geometry><box><size>2 0.6 2</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>2 0.6 2</size></box></geometry>
        <material><ambient>0.7 0.55 0.35 1</ambient></material>
      </visual>
    </link>
    <pose>-9 -6.2 1 0 0 0</pose>
  </model>

