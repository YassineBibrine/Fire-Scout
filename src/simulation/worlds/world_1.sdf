  <!-- Plan de travail -->
  <model name="kitchen_counter">
    <static>true</static>
    <link name="link">
      <collision name="c"><geometry><box><size>3 0.6 0.9</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>3 0.6 0.9</size></box></geometry>
        <material><ambient>0.85 0.85 0.85 1</ambient><diffuse>0.85 0.85 0.85 1</diffuse></material>
      </visual>
    </link>
    <pose>8.5 6.7 0.45 0 0 0</pose>
