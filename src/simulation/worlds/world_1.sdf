  <model name="dining_table">
    <static>true</static>
    <link name="link">
      <collision name="c"><geometry><box><size>2 1 0.75</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>2 1 0.75</size></box></geometry>
        <material><ambient>0.65 0.4 0.15 1</ambient><diffuse>0.65 0.4 0.15 1</diffuse></material>
      </visual>
    </link>
    <pose>6 4 0.375 0 0 0</pose>
  </model>

  <!-- Chaises salle à manger (x4) -->
  <model name="chair1"><static>true</static><link name="link">
    <collision name="c"><geometry><box><size>0.5 0.5 0.9</size></box></geometry></collision>
    <visual name="v"><geometry><box><size>0.5 0.5 0.9</size></box></geometry>
      <material><ambient>0.8 0.6 0.3 1</ambient></material></visual>
  </link><pose>5 4 0.45 0 0 0</pose></model>

  <model name="chair2"><static>true</static><link name="link">
    <collision name="c"><geometry><box><size>0.5 0.5 0.9</size></box></geometry></collision>
    <visual name="v"><geometry><box><size>0.5 0.5 0.9</size></box></geometry>
      <material><ambient>0.8 0.6 0.3 1</ambient></material></visual>
  </link><pose>7 4 0.45 0 0 0</pose></model>

  <model name="chair3"><static>true</static><link name="link">
    <collision name="c"><geometry><box><size>0.5 0.5 0.9</size></box></geometry></collision>
    <visual name="v"><geometry><box><size>0.5 0.5 0.9</size></box></geometry>
      <material><ambient>0.8 0.6 0.3 1</ambient></material></visual>
  </link><pose>6 3.2 0.45 0 0 0</pose></model>

  <model name="chair4"><static>true</static><link name="link">
    <collision name="c"><geometry><box><size>0.5 0.5 0.9</size></box></geometry></collision>
    <visual name="v"><geometry><box><size>0.5 0.5 0.9</size></box></geometry>
      <material><ambient>0.8 0.6 0.3 1</ambient></material></visual>
  </link><pose>6 4.8 0.45 0 0 0</pose></model>

