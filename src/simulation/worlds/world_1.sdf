<?xml version="1.0" ?>
<sdf version="1.9">
<world name="villa_world">

  <scene>
    <ambient>0.95 0.95 0.95 1</ambient>
    <background>0.98 0.98 1 1</background>
    <shadows>true</shadows>
  </scene>

  <light name="sun" type="directional">
    <pose>0 0 20 0 0 0</pose>
    <diffuse>1 1 1 1</diffuse>
    <specular>0.3 0.3 0.3 1</specular>
    <direction>-0.4 -0.3 -1</direction>
    <cast_shadows>true</cast_shadows>
  </light>

  <physics type="ode">
    <max_step_size>0.001</max_step_size>
    <real_time_factor>1</real_time_factor>
  </physics>

  <!-- ===== GROUND ===== -->
  <model name="ground">
    <static>true</static>
    <link name="link">
      <collision name="c"><geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry></collision>
      <visual name="v"><geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry>
        <material><ambient>0.6 0.6 0.6 1</ambient><diffuse>0.6 0.6 0.6 1</diffuse></material>
      </visual>
    </link>
  </model>

  <!-- ===== FLOOR (20x14m) ===== -->
  <model name="villa_floor">
    <static>true</static>
    <link name="link">
      <collision name="c"><geometry><box><size>20 14 0.1</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>20 14 0.1</size></box></geometry>
        <material><ambient>0.92 0.88 0.82 1</ambient><diffuse>0.92 0.88 0.82 1</diffuse></material>
      </visual>
    </link>
    <pose>0 0 0.05 0 0 0</pose>
  </model>

  <!-- ===== MURS EXTERIEURS ===== -->
  <!-- Nord -->
  <model name="wall_north">
    <static>true</static>
    <link name="link">
      <collision name="c"><geometry><box><size>20 0.2 3</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>20 0.2 3</size></box></geometry>
        <material><ambient>0.85 0.82 0.78 1</ambient><diffuse>0.85 0.82 0.78 1</diffuse></material>
      </visual>
    </link>
    <pose>0 7 1.5 0 0 0</pose>
  </model>

  <!-- Sud (avec ouverture porte d'entrée : 2 segments) -->
  <model name="wall_south_left">
    <static>true</static>
    <link name="link">
      <collision name="c"><geometry><box><size>8 0.2 3</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>8 0.2 3</size></box></geometry>
        <material><ambient>0.85 0.82 0.78 1</ambient><diffuse>0.85 0.82 0.78 1</diffuse></material>
      </visual>
    </link>
    <pose>-6 -7 1.5 0 0 0</pose>
  </model>

  <model name="wall_south_right">
    <static>true</static>
    <link name="link">
      <collision name="c"><geometry><box><size>8 0.2 3</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>8 0.2 3</size></box></geometry>
        <material><ambient>0.85 0.82 0.78 1</ambient><diffuse>0.85 0.82 0.78 1</diffuse></material>
      </visual>
    </link>
    <pose>6 -7 1.5 0 0 0</pose>
  </model>

  <!-- Est -->
  <model name="wall_east">
    <static>true</static>
    <link name="link">
      <collision name="c"><geometry><box><size>0.2 14 3</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>0.2 14 3</size></box></geometry>
        <material><ambient>0.85 0.82 0.78 1</ambient><diffuse>0.85 0.82 0.78 1</diffuse></material>
      </visual>
    </link>
    <pose>10 0 1.5 0 0 0</pose>
  </model>

  <!-- Ouest -->
  <model name="wall_west">
    <static>true</static>
    <link name="link">
      <collision name="c"><geometry><box><size>0.2 14 3</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>0.2 14 3</size></box></geometry>
        <material><ambient>0.85 0.82 0.78 1</ambient><diffuse>0.85 0.82 0.78 1</diffuse></material>
      </visual>
    </link>
    <pose>-10 0 1.5 0 0 0</pose>
  </model>

  <!-- ===== MURS INTERIEURS ===== -->

  <!-- Séparation Nord/Sud sur toute la largeur (avec ouverture au centre 2m) -->
  <model name="divider_west">
    <static>true</static>
    <link name="link">
      <collision name="c"><geometry><box><size>9 0.15 3</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>9 0.15 3</size></box></geometry>
        <material><ambient>0.8 0.8 0.8 1</ambient></material>
      </visual>
    </link>
    <pose>-5.5 0 1.5 0 0 0</pose>
  </model>

  <model name="divider_east">
    <static>true</static>
    <link name="link">
      <collision name="c"><geometry><box><size>9 0.15 3</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>9 0.15 3</size></box></geometry>
        <material><ambient>0.8 0.8 0.8 1</ambient></material>
      </visual>
    </link>
    <pose>5.5 0 1.5 0 0 0</pose>
  </model>

  <!-- Chambre 1 (sud-ouest) : mur vertical x=-5 du sud au couloir -->
  <model name="wall_bedroom1">
    <static>true</static>
    <link name="link">
      <collision name="c"><geometry><box><size>0.15 5.5 3</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>0.15 5.5 3</size></box></geometry>
        <material><ambient>0.75 0.7 0.85 1</ambient></material>
      </visual>
    </link>
    <pose>-5 -4.25 1.5 0 0 0</pose>
  </model>

  <!-- Chambre 2 (sud, centre) : mur vertical x=0 -->
  <model name="wall_bedroom2">
    <static>true</static>
    <link name="link">
      <collision name="c"><geometry><box><size>0.15 3.5 3</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>0.15 3.5 3</size></box></geometry>
        <material><ambient>0.75 0.7 0.85 1</ambient></material>
      </visual>
    </link>
    <pose>0 -5.25 1.5 0 0 0</pose>
  </model>

  <!-- Salle de bain (sud-est) : mur vertical x=5 -->
  <model name="wall_bathroom">
    <static>true</static>
    <link name="link">
